  InputLines:
    - '// @input SceneObject arenaRoot {"hint":"The object to pin to the floor — your ArenaRoot."}'
    - "// @input SceneObject camera {\"hint\":\"The device Camera object (the wearer's head). Required: gaze + height come from this.\"}"
    - "// @input SceneObject reticle {\"hint\":\"Optional marker shown at the floor spot you're aiming at while it calibrates.\"}"
    - '// @input bool autoDetectFloor = true {"hint":"ON (recommended): assume a floor below you instantly, then refine to the real floor by looking at it. OFF: classic aim-and-pinch placement."}'
    - '// @input float assumedCameraHeightCm = 110 {"hint":"Assumed distance from your eyes down to the floor, in cm. Used instantly and as the editor/fallback floor (~100–120 for a standing adult)."}'
    - '// @input bool groundOnly = true {"hint":"Only lock onto HORIZONTAL surfaces (real floor), ignoring walls/tilted surfaces."}'
    - '// @input bool matchFloorHeightOnly {"hint":"MANUAL mode only. ON: keep the arena X/Z and just drop it to floor height. OFF: move the whole arena to where you pinch."}'
    - '// @input float maxFloorDistanceCm = 1000 {"hint":"AUTO: how far along your gaze to search for the floor, in cm. 1000 = up to 10 m."}'
    - '// @input float samplesToLock = 15 {"hint":"AUTO: how many steady floor hits in a row before locking. ~10–30. Higher = steadier but slower."}'
    - "// @input float stabilityToleranceCm = 6 {\"hint\":\"AUTO: the floor hit must stay within this many cm to count as 'steady'.\"}"
    - '// @input bool continuousTracking {"hint":"AUTO: keep watching after locking and re-level if the floor drifts beyond the threshold below. OFF = lock once and stay put."}'
    - '// @input float driftThresholdCm = 30 {"hint":"AUTO + continuousTracking: re-level only if the floor moves more than this many cm from the locked height."}'
    - '// @input float placeInFrontCm {"hint":"AUTO: on the first real lock, also slide the arena this many cm in front of you. 0 = leave X/Z where it is."}'
    - // @input bool enableLogging = true
